<configs>

	<!-- Hidden marker buff applied by RestfulRecovery.dll while the player is
	     seated on a chair or couch. Short duration + periodic refresh from the
	     DLL means a stale buff (crash, relog mid-rest) expires on its own. -->
	<append xpath="/buffs">
		<buff name="buffRestfulRecoveryResting" hidden="true">
			<stack_type value="replace"/>
			<duration value="4"/>
		</buff>

		<!-- Visible indicator that the 4x rest bonus is actively working on
		     an injury. Refreshed every tick from the injury buffs below while
		     resting, so it fades out shortly after standing up or healing. -->
		<buff name="buffRestfulRecoveryMending" name_key="buffRestfulRecoveryMendingName" description_key="buffRestfulRecoveryMendingDesc" icon="ui_game_symbol_brokenbone" icon_color="80,220,120">
			<stack_type value="replace"/>
			<duration value="3"/>
			<effect_group>
				<!-- onSelfBuffStart only fires on fresh application (the
				     per-tick refreshes are stacks), so this shows once when
				     the rest bonus kicks in, not every second. -->
				<triggered_effect trigger="onSelfBuffStart" action="ShowToolbeltMessage" message_key="restfulRecoveryMendingToolbelt"/>
			</effect_group>
		</buff>
	</append>

	<!-- Untreated limb injuries drain their recovery counter by
	     @$critHitNaturalHealingRate once per update tick. Three extra drains
	     while resting = 4x total recovery speed. Splinted and cast limbs are
	     separate buffs and are intentionally not patched. -->

	<append xpath="/buffs/buff[@name='buffLegSprained']">
		<effect_group name="RestfulRecovery rest bonus">
			<requirement name="HasBuff" buff="buffRestfulRecoveryResting"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buffRestfulRecoveryMending"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$legHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$legHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$legHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
		</effect_group>
	</append>

	<append xpath="/buffs/buff[@name='buffLegBroken']">
		<effect_group name="RestfulRecovery rest bonus">
			<requirement name="HasBuff" buff="buffRestfulRecoveryResting"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buffRestfulRecoveryMending"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$legHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$legHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$legHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
		</effect_group>
	</append>

	<append xpath="/buffs/buff[@name='buffArmSprained']">
		<effect_group name="RestfulRecovery rest bonus">
			<requirement name="HasBuff" buff="buffRestfulRecoveryResting"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buffRestfulRecoveryMending"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$armHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$armHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$armHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
		</effect_group>
	</append>

	<append xpath="/buffs/buff[@name='buffArmBroken']">
		<effect_group name="RestfulRecovery rest bonus">
			<requirement name="HasBuff" buff="buffRestfulRecoveryResting"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buffRestfulRecoveryMending"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$armHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$armHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
			<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$armHurtCounter" operation="subtract" value="@$critHitNaturalHealingRate"/>
		</effect_group>
	</append>

</configs>
